@model List<TiendaRopa.Models.Producto>
@{
    ViewData["Title"] = "Productos";
}

<div class="page-header">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="fas fa-tshirt"></i> Productos</h1>
            <p class="mb-0" style="color:#ccc;">Gestiona todas las prendas de tu tienda</p>
        </div>
        <a asp-action="Create" class="btn-gold btn">
            <i class="fas fa-plus"></i> Nuevo Producto
        </a>
    </div>
</div>

<div class="container pb-5">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-tshirt fa-4x mb-3" style="color:#e2b96f;"></i>
            <h4>No hay productos aún</h4>
            <p class="text-muted">Agrega tu primer producto</p>
            <a asp-action="Create" class="btn-gold btn mt-2">
                <i class="fas fa-plus"></i> Agregar producto
            </a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var producto in Model)
            {
                <div class="col">
                    <div class="card h-100">
                        @if (!string.IsNullOrEmpty(producto.ImagenUrl))
                        {
                            <img src="@producto.ImagenUrl" class="card-img-top"
                                 style="height:220px; object-fit:cover; border-radius:12px 12px 0 0;" />
                        }
                        else
                        {
                            <div style="height:220px; background:linear-gradient(135deg,#1a1a2e,#0f3460);
                                border-radius:12px 12px 0 0; display:flex;
                                align-items:center; justify-content:center;">
                                <i class="fas fa-tshirt fa-4x" style="color:#e2b96f;"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">@producto.Nombre</h5>
                            <p class="text-muted small mb-1">
                                <i class="fas fa-tag"></i> @(producto.Categoria?.Nombre ?? "Sin categoría")
                            </p>
                            <p class="mb-1">
                                <span class="badge bg-secondary">@producto.Talla</span>
                                <span class="ms-1" style="color:#666;">@producto.Color</span>
                            </p>
                            <p class="fw-bold mt-2" style="color:#0f3460; font-size:1.2rem;">
                                $@producto.Precio.ToString("N0")
                            </p>
                            <div class="mt-auto">
                                @if (producto.Stock > 0)
                                {
                                    <span class="badge-stock">@producto.Stock unid.</span>
                                }
                                else
                                {
                                    <span class="badge-agotado">Agotado</span>
                                }
                                <div class="d-flex gap-2 mt-3">
                                    <a asp-action="Edit" asp-route-id="@producto.Id"
                                       class="btn btn-sm btn-dark-custom flex-fill text-center">
                                        <i class="fas fa-edit"></i> Editar
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@producto.Id"
                                       class="btn btn-sm btn-danger flex-fill text-center"
                                       style="border-radius:25px;">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>