@model List<TiendaRopa.Models.CarritoItem>
@{
    ViewData["Title"] = "Mi Carrito";
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-shopping-cart"></i> Mi Carrito</h1>
        <p class="mb-0" style="color:#ccc;">Revisa los productos seleccionados</p>
    </div>
</div>

<div class="container pb-5">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-shopping-cart fa-4x mb-3" style="color:#e2b96f;"></i>
            <h4>Tu carrito está vacío</h4>
            <a asp-controller="Producto" asp-action="Index" class="btn-gold btn mt-3">
                <i class="fas fa-tshirt"></i> Ver productos
            </a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                @foreach (var item in Model)
                {
                    <div class="card mb-3 p-3">
                        <div class="d-flex align-items-center gap-3">
                            @if (!string.IsNullOrEmpty(item.ImagenUrl))
                            {
                                <img src="@item.ImagenUrl" style="width:80px;height:80px;object-fit:cover;border-radius:8px;" />
                            }
                            else
                            {
                                <div style="width:80px;height:80px;background:linear-gradient(135deg,#1a1a2e,#0f3460);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                                    <i class="fas fa-tshirt" style="color:#e2b96f;"></i>
                                </div>
                            }
                            <div class="flex-grow-1">
                                <h6 class="fw-bold mb-1">@item.Nombre</h6>
                                <p class="mb-0 text-muted small">Cantidad: @item.Cantidad</p>
                                <p class="mb-0" style="color:#0f3460;">$@item.Precio.ToString("N0") c/u</p>
                            </div>
                            <div class="text-end">
                                <p class="fw-bold" style="color:#e2b96f;">$@item.Subtotal.ToString("N0")</p>
                                <form asp-action="Eliminar" method="post">
                                    <input type="hidden" name="productoId" value="@item.ProductoId" />
                                    <button class="btn btn-sm btn-danger" style="border-radius:20px;">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="col-md-4">
                <div class="card p-4">
                    <h5 class="fw-bold mb-3">Resumen</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Total items:</span>
                        <strong>@Model.Sum(i => i.Cantidad)</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Total:</span>
                        <strong style="color:#e2b96f; font-size:1.3rem;">$@Model.Sum(i => i.Subtotal).ToString("N0")</strong>
                    </div>
                    <form asp-action="Vaciar" method="post">
                        <button class="btn btn-dark-custom w-100">
                            <i class="fas fa-trash"></i> Vaciar carrito
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>