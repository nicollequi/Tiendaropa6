@{
    ViewData["Title"] = "Registrar Venta";
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-cash-register"></i> Registrar Venta</h1>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card p-4">
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Producto</label>
                        <select name="productoId" asp-items="ViewBag.Productos" class="form-select">
                            <option value="">-- Selecciona un producto --</option>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Cantidad</label>
                        <input type="number" name="cantidad" class="form-control" min="1" value="1" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn-gold btn">
                            <i class="fas fa-save"></i> Registrar
                        </button>
                        <a asp-action="Index" asp-controller="Producto" class="btn btn-dark-custom">
                            <i class="fas fa-arrow-left"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>